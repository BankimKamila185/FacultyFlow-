# Backend Production Environment Variables
# Copy these to your Render / Railway / Heroku dashboard

PORT=4000
NODE_ENV=production

# Database (Removed after Firebase Migration)
# DATABASE_URL=...

# Security
JWT_SECRET="PLEASE_CHANGE_THIS_TO_A_RANDOM_LONG_STRING"
