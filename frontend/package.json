{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "description": "FacultyFlow - Academic Workflow Automation Framework",
  "author": "Bankim Kamila",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "mobile:ios": "npm run build && npx cap sync ios && npx cap open ios",
    "mobile:android": "npm run build && npx cap sync android && npx cap open android",
    "desktop": "electron .",
    "desktop:dist": "cross-env ELECTRON=true npm run build && electron-builder"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "puppeteer": "^24.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0"
  },
  "build": {
    "appId": "com.facultyflow.app",
    "productName": "FacultyFlow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron/main.cjs",
      "backend/dist/**/*",
      "backend/node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/pwa-512x512.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/pwa-512x512.png"
    }
  }
}
